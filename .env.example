# ─────────────────────────────────────────────────────────────────────────────
# S.T.A.N.D Mentorship — environment variables
# Copy to .env.local (next dev) and .dev.vars (OpenNext/workerd preview). Both gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (Auth + Postgres + Storage) — create a free project at https://supabase.com
# Project settings → API. The anon key is PUBLIC (safe to expose; RLS protects data).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVER-ONLY secret — bypasses RLS. Never expose to the client. (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=

# Email — Resend (used for transactional mail AND as Supabase Auth's custom SMTP).
# PLACEHOLDER for now: reuse existing dev keys; client creates their own at go-live (domain match).
RESEND_API_KEY=
EMAIL_FROM="S.T.A.N.D Mentorship <noreply@standmentorship.org>"

# Bot protection — Cloudflare Turnstile (free). https://dash.cloudflare.com → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Site identity — production canonical URL, no trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare deploy (for `pnpm run deploy`). Optional if you've run `wrangler login`.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# OpenNext local preview
NEXTJS_ENV=development

# Stripe (donations / paid events — added later, not needed for P0)
# STRIPE_TEST_PUBLISHABLE_KEY=
# STRIPE_TEST_SECRET_KEY=
